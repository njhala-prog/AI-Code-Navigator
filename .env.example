# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Security — generate a strong random string for API_KEY
API_KEY=your-secret-api-key-here
ALLOWED_ORIGINS=http://localhost:3000

# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# OpenAI
OPENAI_API_KEY=sk-...

# GitHub (optional — raises rate limits and allows private repos)
GITHUB_TOKEN=ghp_...

# Upload limits
MAX_REPO_MB=50
MAX_FILE_KB=100
